{
  "manifest_version": 3,
  "name": "Smart Rewrite",
  "version": "1.0",
  "description": "Rewrite highlighted text in different tones using Groq AI.",
  "permissions": ["contextMenus", "scripting", "storage", "activeTab"],
  "host_permissions": ["https://api.groq.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}